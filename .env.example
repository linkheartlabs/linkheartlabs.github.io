# GEMINI_API_KEY: Primary key for Gemini AI API calls.
# AI Studio automatically provides GEMINI_API_KEY. 
# Added GEMINI_API_KEY_1 to 5 for redundancy and high availability.
GEMINI_API_KEY=""
VITE_GEMINI_API_KEY=""

GEMINI_API_KEY_1=""
VITE_GEMINI_API_KEY_1=""
GEMINI_API_KEY_2=""
VITE_GEMINI_API_KEY_2=""
GEMINI_API_KEY_3=""
VITE_GEMINI_API_KEY_3=""
GEMINI_API_KEY_4=""
VITE_GEMINI_API_KEY_4=""
GEMINI_API_KEY_5=""
VITE_GEMINI_API_KEY_5=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
